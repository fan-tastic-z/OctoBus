{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "username": {
      "type": "string",
      "description": "WAF login username."
    },
    "user": {
      "type": "string",
      "description": "Legacy alias for username."
    },
    "password": {
      "type": "string",
      "description": "WAF login password."
    },
    "pass": {
      "type": "string",
      "description": "Legacy alias for password."
    }
  }
}
