{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "username": {
      "type": "string",
      "description": "Kibana username for Basic authentication."
    },
    "user": {
      "type": "string",
      "description": "Alias for username."
    },
    "password": {
      "type": "string",
      "description": "Kibana password for Basic authentication."
    },
    "apiKey": {
      "type": "string",
      "description": "Kibana API key. Used when username/password are not set."
    },
    "api_key": {
      "type": "string",
      "description": "Alias for apiKey."
    }
  }
}
